{
  "name": "personal_page",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:ci": "node scripts/download-fonts.js && vite build",
    "preview": "vite preview",
    "deploy": "node scripts/download-fonts.js && vite build && wrangler pages deploy ./build --project-name personalpage --branch main",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@cloudflare/workers-types": "4.20260423.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.2",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "wrangler": "4.84.1"
  },
  "dependencies": {
    "marked": "^18.0.2"
  }
}